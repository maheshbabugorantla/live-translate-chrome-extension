# Python AI service config — copy to `.env`
# Use the key for whichever provider you implement in lib/llm.py
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
# OPENROUTER_API_KEY=...   # route through OpenRouter to keep the provider swappable

MODEL=claude-sonnet-4-6
TRANSLATION_DB_PATH=translations.db

# Optional — shared exact-match cache tier across replicas. Only pays off with
# more than one instance of this service running (e.g. multiple Fly.io
# machines); on a single local process it's a no-op. Leave unset to skip it
# entirely — the service falls back to memory + SQLite exactly as before.
# REDIS_URL=redis://localhost:6379/0
